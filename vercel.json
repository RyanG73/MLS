{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/v1/:path*",
      "destination": "/api"
    }
  ],
  "functions": {
    "api/index.py": {
      "maxDuration": 30,
      "includeFiles": "{webapp/data/**,experiments/champion.json}",
      "excludeFiles": "{data/**,tests/**,output/**,docs/**,archive/**,reports/**,research/**,requirements-dev.txt,requirements-legacy.txt}"
    }
  }
}
