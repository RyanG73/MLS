# Multi-agent experiment runner
# Keep the registry index (experiment history) but ignore large per-run JSON blobs
experiments/*.json
!experiments/registry.jsonl
# Track the blessed champion pointer + its report (the promotion-gate reference)
!experiments/champion.json
!experiments/champion.report.json
!experiments/champion-4fold.report.json
# C2 per-league-family champion pointers + their baseline reports (small, blessed)
!experiments/champion_nwsl.json
!experiments/champion_usl.json
!experiments/nwsl-baseline-4fold.report.json
!experiments/nwsl-xgbonly-4fold.report.json
!experiments/usl-baseline-4fold.report.json
!experiments/champion_eur_big5.json
!experiments/champion_eur_tiers.json
!experiments/eur-big5-family.report.json
!experiments/eur-tiers-family.report.json
# Season-outcome replay baseline (team-level outcome gate; experiment-protocol §4)
!experiments/season-outcomes-baseline.report.json
# Track the Approach C bridge-regression fitted offsets (small, deterministic output)
!experiments/league_offsets.json
# Track the tier-2 → tier-1 ELO offsets (small, deterministic output of tier_bridge.py)
!experiments/tier2_offsets.json
# Track B4's trust-slice source: same champion config as challenger-bag5.report.json,
# regenerated with current model_report.py so A1's slices + A3's promoted_team_brier
# are populated (the pinned challenger-bag5.report.json predates both). Regenerate via
# `model_report.py --frame data/parity_frame.parquet --label b4-trust-baseline --out
# experiments/b4-trust-baseline.report.json` whenever the champion config changes.
!experiments/b4-trust-baseline.report.json
# Probe blend cache (large, regenerable)
experiments/_referee_blends.pkl

